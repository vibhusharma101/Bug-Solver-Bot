# =============================================
# BUG SOLVER BOT — Environment Configuration
# =============================================
# Copy this file to .env and fill in all values
# NEVER commit .env to source control

# --- Anthropic (Claude AI) ---
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- GitHub ---
# Create a PAT at: https://github.com/settings/tokens
# Required scopes: repo (full access)
GITHUB_TOKEN=ghp_...
# Your GitHub username or org name
GITHUB_OWNER=your-org-or-username
# The repository the bot should create PRs in
GITHUB_REPO=your-repo-name
# Default base branch for PRs (usually main or master)
GITHUB_BASE_BRANCH=main

# --- Sentry ---
# Create at: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: project:read, event:read
SENTRY_AUTH_TOKEN=sntrys_...
# Your Sentry organization slug (from your Sentry URL)
SENTRY_ORG=your-sentry-org-slug
# Your Sentry project slug
SENTRY_PROJECT=your-project-slug

# --- Slack (optional) ---
# Create an Incoming Webhook at: https://api.slack.com/apps
# Leave blank to disable Slack notifications
SLACK_WEBHOOK_URL=

# --- Bot Behavior ---
# How many bugs to fix per daily run (default: 5)
MAX_BUGS_PER_RUN=5
# Cron schedule for the daily run (default: 11 AM every day)
# Format: "minute hour day-of-month month day-of-week"
CRON_SCHEDULE=0 11 * * *
# Set to "true" to skip actual API calls (for testing)
DRY_RUN=false
